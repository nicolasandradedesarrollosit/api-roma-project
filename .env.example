# Server
PORT=3001
NODE_ENV=production
# Frontend public URL allowed by CORS, e.g. https://roma-project.onrender.com
ALLOWED_ORIGIN=https://your-frontend-domain.com

# Database
MONGO_URI=mongodb://localhost:27017/roma-ceramic

# JWT
JWT_SECRET=your_jwt_secret_key_here_min_32_chars_required
JWT_EXPIRES_IN=7d

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
# Keep line breaks escaped as \n when storing this in env providers like Render
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
